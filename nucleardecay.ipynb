import numpy as np
import matplotlib.pyplot as plt
import random

def n5000():
    
    t=0
    timeval=[]
    nvals=[]
    n=5000 #number of atoms
    dec_const=0.1 #assumption
    time_step=1 #assumption 
    prob=dec_const*time_step
    for j in range(50):
        k=0
        N= np.random.rand(n)
        for i in N:
            if i<prob: #decays
                k+=1
            elif i>=prob: #survives
                pass

        n=n-k
        t+=time_step
        timeval.append(t)
        nvals.append(n)
    return timeval,nvals
def n50():
    t2=0
    timeval2=[]
    nvals2=[]
    n=50 #number of atoms
    dec_const=0.1 #assumption
